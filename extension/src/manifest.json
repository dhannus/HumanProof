{
  "manifest_version": 3,
  "name": "HumanProof",
  "version": "0.1.0",
  "description": "Prove you are human online — anonymously. A Zero-Knowledge Proof-based identity layer for the web.",

  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "HumanProof — Click to verify"
  },

  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],

  "permissions": [
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "web_accessible_resources": [
    {
      "resources": ["src/zkp-worker.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
